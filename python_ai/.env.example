# Python AI Service Configuration

# Google Gemini API Key (Optional)
# Get your API key from: https://makersuite.google.com/app/apikey
# This enables intelligent fallback responses for queries that don't match predefined service patterns
# Service works without this key - gracefully degrades to standard messages
GEMINI_API_KEY=your_real_key_here

# Flask Configuration (Optional - defaults shown)
# FLASK_ENV=development
# FLASK_DEBUG=True

# MongoDB Persistence (Optional but recommended in production)
# Used to persist deep-learning model state and feedback samples across redeploys.
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=servpro_ai
# MONGODB_CONNECT_TIMEOUT_MS=3000

# Manual learning endpoint guard
# Set to false in production to prevent manual /feedback submissions
# MANUAL_FEEDBACK_ENABLED=false

# Live backend context fetch for each prompt
# BACKEND_CONTEXT_ENABLED=true
# BACKEND_CONTEXT_BASE_URL=http://localhost:4000
# BACKEND_CONTEXT_TIMEOUT_SECONDS=4
# BACKEND_CONTEXT_MAX_ITEMS=50
