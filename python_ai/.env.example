# Python AI Service Configuration

# Google Gemini API Key (Optional)
# Get your API key from: https://makersuite.google.com/app/apikey
# This enables intelligent fallback responses for queries that don't match predefined service patterns
# Service works without this key - gracefully degrades to standard messages
GEMINI_API_KEY=your_real_key_here

# Flask Configuration (Optional - defaults shown)
# FLASK_ENV=development
# FLASK_DEBUG=True
